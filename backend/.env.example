# ===========================================
# RestaurantEngin Backend - Environment Template
# Copy to .env and fill in values. Never commit .env.
# For production (e.g. DigitalOcean) set these in App Platform or on the server.
# ===========================================

# --- Server ---
NODE_ENV=production
PORT=3000
API_BASE_URL=https://your-api-domain.com

# --- Database (MySQL) ---
# DigitalOcean Managed MySQL: use host/port/user/password from Control Panel
# Droplet: typically localhost, 3306
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=restaurant_websites
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
# SSL Mode: REQUIRED for DigitalOcean Managed MySQL, omit for local/dev
# MYSQL_SSL_MODE=REQUIRED

# --- JWT (required; use a long random string in production) ---
JWT_SECRET=change-this-to-a-long-random-string
# ACCESS_TOKEN_EXPIRY=1h
# REFRESH_TOKEN_EXPIRY=7d

# --- Redis (optional; app works without it, no cache) ---
# DigitalOcean Managed Redis: use connection string from Control Panel
# REDIS_URL=redis://localhost:6379
# REDIS_AUTO_CONNECT=true

# --- Frontend / CORS ---
FRONTEND_URL=https://your-frontend-domain.com

# --- Firebase (orders sync, push, Android) ---
# Service account JSON: project_id in file is the Firebase/Google Cloud project (e.g. tashkeela-8cab1).
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
#
# Realtime Database URL (europe-west1 example matches pushNotificationService.js default):
# FIREBASE_DATABASE_URL=https://tashkeela-8cab1-default-rtdb.europe-west1.firebasedatabase.app
#
# Web API key (Firebase Console → Project settings → General → Web API key).
# Use the SAME value for the frontend Vite build: VITE_FIREBASE_API_KEY
# FIREBASE_WEB_API_KEY=
# FIREBASE_BACKEND_UID=your-backend-uid
#
# --- Frontend (Vite) — copy into RestaurantEngin/frontend/.env.local or DO build env ---
# VITE_FIREBASE_API_KEY=<same as FIREBASE_WEB_API_KEY>
# VITE_FIREBASE_AUTH_DOMAIN=tashkeela-8cab1.firebaseapp.com
# VITE_FIREBASE_DATABASE_URL=https://tashkeela-8cab1-default-rtdb.europe-west1.firebasedatabase.app
# VITE_FIREBASE_PROJECT_ID=tashkeela-8cab1
# VITE_FIREBASE_APP_ID=<optional: add a Web app in Firebase Console → App ID 1:…:web:…>

# --- Menu extractor (optional) ---
# OPENAI_API_KEY=sk-...

# --- Payments (optional) ---
# PAYTABS_PROFILE_ID=
# PAYTABS_SERVER_KEY=
# STRIPE_SECRET_KEY=

# --- Email (optional) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# --- Android / dev only ---
# ANDROID_EMULATOR_URL=http://10.0.2.2:3000

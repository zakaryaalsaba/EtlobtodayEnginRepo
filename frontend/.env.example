# Copy to .env.local (local) or set in CI / DigitalOcean for production builds.
# Derived from backend Firebase project (firebase-service-account.json project_id + pushNotificationService default RTDB host).

# Web API key — same value as backend FIREBASE_WEB_API_KEY (Firebase Console → Project settings → General → Web API key).
VITE_FIREBASE_API_KEY=

VITE_FIREBASE_AUTH_DOMAIN=tashkeela-8cab1.firebaseapp.com

# Same as backend FIREBASE_DATABASE_URL (no trailing slash).
VITE_FIREBASE_DATABASE_URL=https://tashkeela-8cab1-default-rtdb.europe-west1.firebasedatabase.app

# Same as service account "project_id".
VITE_FIREBASE_PROJECT_ID=tashkeela-8cab1

# Optional for Realtime DB only: Firebase Console → Project settings → Your apps → Web app → App ID (1:…:web:…).
# Leave empty if you only use apiKey + projectId + databaseURL.
VITE_FIREBASE_APP_ID=

# Optional
# VITE_FIREBASE_STORAGE_BUCKET=tashkeela-8cab1.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
